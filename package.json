{
    "name": "hourse-racing-app",
    "private": true,
    "packageManager": "pnpm@9.15.4",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "start": "turbo run start",
        "lint": "turbo run lint",
        "tsc": "turbo run tsc",
        "test": "turbo run test",
        "clean": "turbo run clean && rm -rf node_modules",
        "strapi": "npm run -w @horse-racing/strapi",
        "dev:strapi": "npm run dev -w @horse-racing/strapi",
        "build:strapi": "npm run build -w @horse-racing/strapi",
        "start:strapi": "npm run start -w @horse-racing/strapi",
        "frontend": "npm run -w @horse-racing/frontend",
        "dev:frontend": "npm run dev -w @horse-racing/frontend",
        "build:frontend": "npm run build -w @horse-racing/frontend",
        "start:frontend": "npm run start -w @horse-racing/frontend",
        "pm2:dev:start": "pm2 start ecosystem.dev.config.cjs",
        "pm2:prod:start": "pm2 start ecosystem.prod.config.cjs",
        "pm2:dev:reload": "pm2 reload ecosystem.dev.config.cjs --update-env",
        "pm2:prod:reload": "pm2 reload ecosystem.prod.config.cjs --update-env",
        "transfer:db": "bash scripts/transfer-db-to-server.sh"
    },
    "devDependencies": {
        "turbo": "^2.4.4"
    },
    "engines": {
        "node": ">=20"
    },
    "pnpm": {
        "packageExtensions": {
            "@strapi/core": {
                "dependencies": {
                    "bcryptjs": "2.4.3"
                }
            }
        }
    }
}