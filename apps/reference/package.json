{
  "name": "hk-horse-racing",
  "version": "1.0.0",
  "description": "AI-assisted Hong Kong horse racing analysis and betting recommendation system",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "scrape:racecard": "tsx src/scrapers/raceCard.ts",
    "scrape:historical": "tsx src/scrapers/historical.ts",
    "analyze": "tsx tools/analyze-race.ts",
    "odds": "tsx tools/fetch-odds.ts",
    "jockeys": "tsx tools/fetch-jockey-stats.ts",
    "backtest": "tsx tools/run-backtest.ts",
    "lint": "eslint src/**/*.ts",
    "test": "vitest"
  },
  "keywords": [
    "horse-racing",
    "hkjc",
    "betting",
    "analysis",
    "monte-carlo"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/lodash": "^4.17.0",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "date-fns": "^3.3.0",
    "lodash": "^4.17.21",
    "playwright": "^1.41.0",
    "zod": "^3.22.0"
  }
}
