# ─── Server ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=1337
APP_URL=http://localhost:8081

# ─── Secrets (generate your own) ─────────────────────────
APP_KEYS=<base64>,<base64>,<base64>,<base64>
API_TOKEN_SALT=<base64>
ADMIN_JWT_SECRET=<base64>
TRANSFER_TOKEN_SALT=<base64>
ENCRYPTION_KEY=<base64>
JWT_SECRET=<base64>

# ─── Database ─────────────────────────────────────────────
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db
# For non-SQLite databases:
# DATABASE_HOST=
# DATABASE_PORT=
# DATABASE_NAME=
# DATABASE_USERNAME=
# DATABASE_PASSWORD=
# DATABASE_SSL=false

# ─── HKJC Sync ───────────────────────────────────────────
# Secret for POST /api/hkjc-sync/trigger/* (min 8 chars)
HKJC_SYNC_TRIGGER_SECRET=

# Base URL for HKJC scraping (default: https://racing.hkjc.com)
# HKJC_BASE_URL=https://racing.hkjc.com

# Rate limit for scraping requests per minute (default: 20)
# HKJC_RATE_LIMIT_PER_MIN=20

# Run Playwright in headless mode (default: true)
# HKJC_PLAYWRIGHT_HEADLESS=true

# Toggle individual sync features (default: true)
# HKJC_FIXTURE_FETCH_ENABLED=true
# HKJC_MEETING_DETAILS_FETCH_ENABLED=true
# HKJC_HISTORICAL_SYNC_ENABLED=true
# HKJC_BETTING_ODDS_FETCH_ENABLED=true
# HKJC_PERSON_SYNC_ENABLED=true
# HKJC_HORSE_PROFILE_FETCH_ENABLED=true

# Max fixtures to process per history sync run (default: Infinity)
# HKJC_HISTORICAL_MAX_PER_RUN=

# Seed fixtures on boot from a JSON file
# HKJC_FIXTURE_SEED_FILE=
# HKJC_FIXTURE_SYNC_ON_BOOT=true

# ─── HKJC Cron Jobs ──────────────────────────────────────
# Master toggle (default: true)
# HKJC_CRON_ENABLED=true

# Timezone (default: Asia/Hong_Kong)
# HKJC_CRON_TZ=Asia/Hong_Kong

# Cron schedules (defaults shown)
# HKJC_CRON_FIXTURE_SCHEDULE=0 0 * * *
# HKJC_CRON_MEETINGS_SCHEDULE=0 6 * * *
# HKJC_CRON_HISTORY_SCHEDULE=0 19 * * *,0 23 * * *
# HKJC_CRON_ANALYSIS_SCHEDULE=0 8 * * *

# Run all jobs on boot (default: false)
# HKJC_CRON_RUN_ON_BOOT=false

# ─── Twilio (OTP Authentication) ─────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ─── Google reCAPTCHA ─────────────────────────────────────
# Server-side secret key (skip to disable verification)
RECAPTCHA_SECRET_KEY=

# ─── Stripe (Subscriptions) ──────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
