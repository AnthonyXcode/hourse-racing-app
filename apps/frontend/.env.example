# ─── Strapi API ───────────────────────────────────────────
# Base URL for the Strapi REST API (include /api suffix)
EXPO_PUBLIC_STRAPI_URL=http://localhost:1337/api

# ─── Google reCAPTCHA ─────────────────────────────────────
# Client-side site key (leave empty to skip reCAPTCHA)
EXPO_PUBLIC_RECAPTCHA_SITE_KEY=
# Base URL for reCAPTCHA verification (default: https://www.google.com)
EXPO_PUBLIC_RECAPTCHA_BASE_URL=https://www.google.com
