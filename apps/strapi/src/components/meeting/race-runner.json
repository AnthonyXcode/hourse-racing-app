{
  "collectionName": "components_meeting_race_runners",
  "info": {
    "displayName": "Race runner",
    "description": "Horse line-up fields aligned with history.finish-placing, excluding result-only fields (position, time, margin, odds)"
  },
  "options": {},
  "attributes": {
    "horseNumber": {
      "type": "integer",
      "required": true,
      "min": 1
    },
    "horseName": {
      "type": "string"
    },
    "horseCode": {
      "type": "string"
    },
    "jockeyName": {
      "type": "string"
    },
    "jockeyId": {
      "type": "string",
      "description": "HKJC jockey id from profile URL"
    },
    "trainerName": {
      "type": "string"
    },
    "trainerId": {
      "type": "string",
      "description": "HKJC trainer id from profile URL"
    },
    "jockey": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::jockey.jockey"
    },
    "trainer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::trainer.trainer"
    }
  }
}
