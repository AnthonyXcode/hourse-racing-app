{
  "kind": "collectionType",
  "collectionName": "meetings",
  "info": {
    "singularName": "meeting",
    "pluralName": "meetings",
    "displayName": "Meeting"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "key": {
      "type": "string",
      "required": true,
      "unique": true,
      "description": "Format: yyyy-MM-dd_VV_RN for per-race records (e.g. 2025-10-01_ST_R1) or yyyy-MM-dd_VV for history-only records (e.g. 2025-10-01_ST)"
    },
    "raceDate": {
      "type": "date",
      "required": true
    },
    "venue": {
      "type": "enumeration",
      "enum": ["ST", "HV"],
      "required": true
    },
    "raceNumber": {
      "type": "integer",
      "min": 1
    },
    "raceName": {
      "type": "string"
    },
    "raceClass": {
      "type": "string"
    },
    "distance": {
      "type": "integer",
      "min": 0
    },
    "surface": {
      "type": "enumeration",
      "enum": ["Turf", "AWT"]
    },
    "going": {
      "type": "enumeration",
      "enum": [
        "Firm",
        "Good to Firm",
        "Good",
        "Good to Yielding",
        "Yielding",
        "Soft",
        "Heavy",
        "Wet Fast",
        "Wet Slow"
      ]
    },
    "prizeMoney": {
      "type": "biginteger"
    },
    "runners": {
      "type": "component",
      "repeatable": true,
      "component": "meeting.race-runner"
    },
    "scrapeStatus": {
      "type": "enumeration",
      "enum": ["not_started", "pending", "success", "failed", "partial"],
      "default": "not_started"
    },
    "lastScrapedAt": {
      "type": "datetime"
    },
    "source": {
      "type": "string",
      "default": "hkjc"
    },
    "raceDetailsScrapedAt": {
      "type": "datetime"
    }
  }
}
